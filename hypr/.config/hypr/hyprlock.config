##############
# GENERAL
##############
general {
    hide_cursor = true
    ignore_empty_input = false
    immediate_render = true
    text_trim = true

    # Wayland + mixed‑DPI is common; auto usually works well
    fractional_scaling = 2

    # GPU screencopy is fine on Gentoo if drivers are set up
    screencopy_mode = 0

    # 2s UI reset after wrong password
    fail_timeout = 2000
}

##############
# AUTH
##############
auth {
    pam:enabled = true
    pam:module = hyprlock

    # Enable this only if you have fprintd configured
    fingerprint:enabled = false
    fingerprint:ready_message = Scan fingerprint to unlock
    fingerprint:present_message = Scanning fingerprint
    fingerprint:retry_delay = 250
}

##############
# ANIMATIONS
##############
animations {
    enabled = true
    bezier = gentoo, 0.25, 0.1, 0.25, 1.0
    animation = global, 1, 0.35, gentoo
    animation = fade, 1, 0.35, gentoo
    animation = fadeIn, 1, 0.35, gentoo
    animation = fadeOut, 1, 0.25, gentoo
    animation = inputFieldFade, 1, 0.25, gentoo
}

##############
# BACKGROUND
##############
# Main: blurred screenshot with gentle purple tint
background {
    monitor = 
    path = screenshot
    color = rgba(20, 15, 30, 1.0)

    blur_passes = 3
    blur_size = 8
    noise = 0.015
    contrast = 0.9
    brightness = 0.85
    vibrancy = 0.18
    vibrancy_darkness = 0.06

    reload_time = -1
    crossfade_time = 0.25

    zindex = -1
}

##############
# GENTOO LOGO (CENTER)
##############
# Put some Gentoo logo PNG here, e.g.:
# ~/.local/share/icons/gentoo-logo.png
image {
    monitor = 
    path = ~/.local/share/icons/gentoo-logo.png

    size = 220
    rounding = -1

    border_size = 4
    border_color = rgba(180, 160, 255, 1.0)

    position = 0, -150
    halign = center
    valign = center

    shadow_passes = 1
    shadow_size = 8
    shadow_color = rgba(0,0,0,0.9)
    shadow_boost = 1.4

    zindex = 1
}

##############
# TIME + DATE
##############
label {
    monitor = 
    text = <span font_desc="Sans 42" foreground="#E0D4FF" weight="bold" allow_breaks="false">$TIME12</span>
    position = 0, -40
    halign = center
    valign = center

    zindex = 2
}

label {
    monitor = 
    text = <span font_desc="Sans 18" foreground="#B7A9FF" allow_breaks="false">$TIME</span>
    position = 0, 5
    halign = center
    valign = center

    zindex = 2
}

##############
# GENTOO TAGLINE / HOST INFO
##############
label {
    monitor =
    text = <span font_desc="Sans 14" foreground="#C9B8FF" allow_breaks="true">Gentoo Linux<br/>$USER@$DESC</span>
    position = 0, 60
    halign = center
    valign = center

    zindex = 2
}

##############
# INPUT FIELD
##############
input-field {
    monitor = 

    size = 35%, 42
    outline_thickness = 2

    rounding = 16

    # Background color(s) and gradient
    inner_color = rgba(14, 10, 24, 0.85)
    outer_color = rgba(90, 70, 150, 0.9)
    border_color = rgba(205, 190, 255, 1.0)

    # Adaptive width + subtle animation
    fade_on_empty = true
    placeholder_text = <span font_desc="Sans 11" foreground="#8E80D5">Enter password for $USER on Gentoo</span>

    # Dots
    font_color = rgba(230, 220, 255, 1.0)
    font_size = 18

    # Position: under logo/time
    position = 0, 140
    halign = center
    valign = center

    # Shadow
    shadow_passes = 1
    shadow_size = 10
    shadow_color = rgba(0,0,0,0.9)
    shadow_boost = 1.6

    # Wrong-password feedback
    fail_color = rgba(220, 80, 100, 1.0)
    fail_border_color = rgba(255, 120, 140, 1.0)

    zindex = 3
}

##############
# AUTH MESSAGES (ERRORS, PROMPTS)
##############
label {
    monitor = 
    text = <span font_desc="Sans 11" foreground="#F28FA9" allow_breaks="true">$FAIL$PAMFAIL</span>
    position = 0, 190
    halign = center
    valign = center

    zindex = 3
}

label {
    monitor =
    text = <span font_desc="Sans 11" foreground="#C9B8FF" allow_breaks="true">$PAMPROMPT</span>
    position = 0, 215
    halign = center
    valign = center

    zindex = 3
}

##############
# KEYBOARD LAYOUT INDICATOR
##############
label {
    monitor =
    text = <span font_desc="Sans 10" foreground="#B7A9FF" allow_breaks="false">KB: $LAYOUT</span>
    position = 20, -20
    halign = left
    valign = bottom

    zindex = 3
}

##############
# ATTEMPTS / SECURITY HINT
##############
label {
    monitor =
    text = <span font_desc="Sans 10" foreground="#8E80D5" allow_breaks="true">Failed attempts: $ATTEMPTS</span>
    position = -20, -20
    halign = right
    valign = bottom

    zindex = 3
}

